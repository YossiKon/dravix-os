# ── dravix-os configuration ───────────────────────────────────────────────
# Copy to ".env" and fill in. Never commit the real .env (it's gitignored).

# ── Service ────────────────────────────────────────────────────────────────
DRAVIX_HOST=0.0.0.0
DRAVIX_PORT=8800
DRAVIX_LOG_LEVEL=INFO
# Where runtime state (store.json: personas, routines, memory, schedule, ...) lives. Blank = repo data/.
DRAVIX_DATA_DIR=
# Optional API auth token. When set, every /api/* and /camera/* request (except /api/health)
# must carry it: "Authorization: Bearer <token>", "X-API-Token: <token>", or "?token=<token>".
# Blank (default) = no auth, unchanged behavior.
DRAVIX_API_TOKEN=
# Language for the built-in wellness tips: en | he. (The dashboard/store can override.)
DRAVIX_LANG=en
# Expose the risky tools (generic HA service call, lock/unlock, alarm disarm) on dravix's own
# MCP server to connected agents. Keep false unless you really want remote unlock/disarm.
DRAVIX_EXPOSE_RISKY_TOOLS=false

# ── Robot (StackChan) ────────────────────────────────────────────────────────
# Backend the Device Abstraction Layer uses:
#   ha   = real control via Home Assistant + the custom dravix ESPHome firmware
#          (docs/esphome-local-control.md). This is the supported path.
#   mock = offline dev / tests — no robot needed.
DRAVIX_ROBOT_DRIVER=mock

# ── Home Assistant ───────────────────────────────────────────────────────────
# Base URL of your HA instance.
DRAVIX_HA_URL=http://homeassistant.local:8123
# Long-lived access token (HA → profile → Long-Lived Access Tokens).
DRAVIX_HA_TOKEN=
# HA's MCP Server endpoint (from the "MCP Server" integration), if enabled.
# Usually: <DRAVIX_HA_URL>/mcp_server/sse
DRAVIX_HA_MCP_URL=

# Event bridge: stream HA state changes onto dravix's bus (drives guard/presence modes).
DRAVIX_HA_EVENTS_ENABLED=true
# Optional explicit entity->event map (JSON). binary_sensors auto-map by device_class anyway.
# Example: {"binary_sensor.office_motion":"ha.motion","binary_sensor.front_door":"ha.door"}
DRAVIX_HA_EVENT_MAP={}
# When DRAVIX_ROBOT_DRIVER=ha, map the robot's HA entities (JSON). Keys: head_yaw, head_pitch,
# media_player, led_light. Example: {"media_player":"media_player.stackchan","led_light":"light.stackchan"}
DRAVIX_HA_ROBOT_ENTITIES={}

# ── AI router ────────────────────────────────────────────────────────────────
# Default conversation provider: ha_assist | claude | openai | ollama
DRAVIX_AI_PROVIDER=ha_assist
# Optional explicit HA Assist agent/pipeline id (blank = HA default).
DRAVIX_HA_ASSIST_AGENT=
# Max tokens per spoken reply (keep small for snappy speech).
DRAVIX_AI_MAX_TOKENS=512

# Models per provider (only the selected provider's model is used).
# Claude: claude-opus-4-8 (most capable) · claude-haiku-4-5 (fast/cheap) · claude-sonnet-4-6 (balanced)
DRAVIX_CLAUDE_MODEL=claude-opus-4-8
DRAVIX_OPENAI_MODEL=gpt-4o-mini
DRAVIX_OLLAMA_MODEL=llama3.2

# Keys for non-default providers (only needed if you switch providers).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# ── Local-first ──────────────────────────────────────────────────────────────
# When true, cloud AI providers (claude/openai) are refused — everything stays on your box.
# Use ha_assist (with a local HA pipeline: Ollama + faster-whisper + Piper) or ollama.
DRAVIX_LOCAL_ONLY=true

# ── Cameras / Frigate (all local) ────────────────────────────────────────────
# Optional direct Frigate base URL; otherwise snapshots come via Home Assistant's camera proxy.
DRAVIX_FRIGATE_URL=
# Default camera entity to show on the robot, e.g. camera.front_door
DRAVIX_FRIGATE_CAMERA=
# Home Assistant weather entity for /api/say/weather, e.g. weather.home
DRAVIX_WEATHER_ENTITY=
